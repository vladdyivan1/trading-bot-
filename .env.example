ENVIRONMENT=paper
LOG_LEVEL=INFO
DATABASE_URL=sqlite:////app/data/spy_scalper.db

# Optional shared secret. Include this value as "secret" in TradingView JSON.
WEBHOOK_SECRET=

# Feature flags. Keep broker execution disabled until a live adapter is audited.
ENABLE_AI_FILTER=true
ENABLE_NEWS_FILTER=true
ENABLE_BROKER_EXECUTION=false
PAPER_TRADING=true
KILL_SWITCH=false

# Risk preset: conservative, standard, aggressive.
RISK_PRESET=standard
MAX_DAILY_LOSS=500
MAX_TRADES_PER_DAY=8
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_STOP_MINUTES=10
MAX_CAPITAL_AT_RISK_PER_TRADE=350
MAX_TOTAL_EXPOSURE=1000
MAX_HOLD_MINUTES=20

# Options contract filters.
DEFAULT_DTE=0
FALLBACK_DTE=1
TARGET_DELTA_MIN=0.45
TARGET_DELTA_MAX=0.65
MIN_OPTION_OPEN_INTEREST=500
MIN_OPTION_VOLUME=100
MAX_OPTION_SPREAD_PCT=0.18

# News provider defaults to mock for offline development.
NEWS_PROVIDER=mock
NEWS_RSS_URLS=[]
LLM_PROVIDER=mock
