APP_NAME=tv-0dte-ai-scalper
APP_ENV=dev
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/scalper.db
REDIS_URL=

WEBHOOK_SECRET=change-me
WEBHOOK_STALE_SECONDS=45
DUPLICATE_WINDOW_SECONDS=20

RISK_PRESET=standard
MAX_DAILY_LOSS=-1000
MAX_TRADES_PER_DAY=12
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES_AFTER_LOSS=10
MAX_CAPITAL_PER_TRADE=1500
MAX_TOTAL_EXPOSURE=8000
MAX_HOLD_MINUTES_DEFAULT=12
NO_TRADE_FIRST_MINUTES=5
ENFORCE_EVENT_BLACKOUT=true
HARD_KILL_SWITCH=false

SESSION_MORNING_START=09:35
SESSION_MORNING_END=11:30
SESSION_AFTERNOON_ENABLED=true
SESSION_AFTERNOON_START=13:30
SESSION_AFTERNOON_END=15:30
REJECT_LUNCH_PERIOD=true
REJECT_AFTER_TIME_ET=15:15

AI_FILTERING_ENABLED=true
NEWS_FILTERING_ENABLED=true
BROKER_EXECUTION_ENABLED=false
PAPER_TRADING_MODE=true
BROKER_ADAPTER=paper

OPTIONS_DEFAULT_DTE=0
OPTIONS_FALLBACK_DTE=1
OPTIONS_DELTA_MIN=0.35
OPTIONS_DELTA_MAX=0.6
OPTIONS_MIN_OPEN_INTEREST=100
OPTIONS_MIN_VOLUME=100
OPTIONS_MAX_SPREAD_PCT=0.12
DEFAULT_CONTRACT_QTY=1

MOCK_NEWS_PROVIDER=true
MOCK_AI_PROVIDER=true
NEWS_API_URL=https://newsapi.org/v2
NEWS_API_KEY=
