//@version=5
strategy("SPY 0DTE Scalper", overlay=true, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=10, initial_capital=100000, commission_type=strategy.commission.cash_per_order, commission_value=0.65, process_orders_on_close=false)

// ─── Inputs ───────────────────────────────────────────────────────────────────
entryMode       = input.string("Conservative", "Entry Mode", options=["Aggressive", "Conservative"])
useORB          = input.bool(true, "Enable Opening Range Breakout")
amSessionStart  = input.session("0935-1130", "AM Session (ET)")
pmSession       = input.bool(true, "Enable PM Session")
pmSessionStart  = input.session("1330-1530", "PM Session (ET)")
skipLunch       = input.bool(true, "No-Trade Lunch (11:30-13:30 ET)")

emaFastLen      = input.int(9, "EMA Fast")
emaSlowLen      = input.int(21, "EMA Slow")
rsiLen          = input.int(14, "RSI Length")
rsiBullMin      = input.int(52, "RSI Bull Min (Conservative +5)")
rsiBearMax      = input.int(48, "RSI Bear Max (Conservative -5)")
macdFast        = input.int(12, "MACD Fast")
macdSlow        = input.int(26, "MACD Slow")
macdSig         = input.int(9, "MACD Signal")
atrLen          = input.int(14, "ATR Length")
atrStopMult     = input.float(1.2, "ATR Stop Mult")
atrTargetMult   = input.float(1.8, "ATR Target Mult")
volSpikeMult    = input.float(1.5, "Volume Spike vs SMA20")
orbBars         = input.int(6, "ORB Bars (1m chart ≈ 6 min)")

// ─── Indicators ───────────────────────────────────────────────────────────────
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
vwapVal = ta.vwap(hlc3)
rsiVal  = ta.rsi(close, rsiLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)
atrVal  = ta.atr(atrLen)
volSma  = ta.sma(volume, 20)
volSpike = volume > volSma * volSpikeMult

// Opening range
var float orbHigh = na
var float orbLow  = na
var bool  orbSet  = false
newDay = ta.change(time("D"))
if newDay
    orbHigh := na
    orbLow  := na
    orbSet  := false
if not orbSet and useORB
    orbHigh := ta.highest(high, orbBars)
    orbLow  := ta.lowest(low, orbBars)
    if bar_index >= orbBars
        orbSet := true

// ─── Session filters ──────────────────────────────────────────────────────────
inAM  = not na(time(timeframe.period, amSessionStart))
inPM  = pmSession and not na(time(timeframe.period, pmSessionStart))
inLunch = skipLunch and not na(time(timeframe.period, "1130-1330"))
inTradeSession = (inAM or inPM) and not inLunch

// ─── Signal logic ─────────────────────────────────────────────────────────────
bullTrend = emaFast > emaSlow and close > vwapVal
bearTrend = emaFast < emaSlow and close < vwapVal
macdBull  = macdHist > 0 and macdLine > macdSignal
macdBear  = macdHist < 0 and macdLine < macdSignal

rsiBullTh = entryMode == "Aggressive" ? 50 : rsiBullMin
rsiBearTh = entryMode == "Aggressive" ? 50 : rsiBearMax
rsiBullOk = rsiVal > rsiBullTh
rsiBearOk = rsiVal < rsiBearTh

orbBull = useORB and orbSet and close > orbHigh
orbBear = useORB and orbSet and close < orbLow

longSetup  = inTradeSession and bullTrend and rsiBullOk and macdBull and volSpike and (not useORB or orbBull)
shortSetup = inTradeSession and bearTrend and rsiBearOk and macdBear and volSpike and (not useORB or orbBear)

// Avoid simultaneous conflicts — only one direction
var int biasState = 0  // 1 bull, -1 bear
if longSetup and not shortSetup
    biasState := 1
else if shortSetup and not longSetup
    biasState := -1

canLong  = longSetup and strategy.position_size <= 0
canShort = shortSetup and strategy.position_size >= 0

stopLong  = close - atrVal * atrStopMult
targetLong = close + atrVal * atrTargetMult
stopShort  = close + atrVal * atrStopMult
targetShort = close - atrVal * atrTargetMult

if canLong
    strategy.entry("LongCall", strategy.long, comment="CALL_BIAS")
    strategy.exit("LX", "LongCall", stop=stopLong, limit=targetLong)
if canShort
    strategy.entry("ShortPut", strategy.short, comment="PUT_BIAS")
    strategy.exit("SX", "ShortPut", stop=stopShort, limit=targetShort)

// ─── Dynamic state strings for webhook JSON ───────────────────────────────────
biasStr = biasState == 1 ? "bullish" : biasState == -1 ? "bearish" : "neutral"
macdStateStr = macdBull ? "bullish" : macdBear ? "bearish" : "neutral"
volStateStr = volSpike ? "spike" : "normal"
vwapStateStr = close > vwapVal ? "above" : close < vwapVal ? "below" : "at"

// ─── Plots ────────────────────────────────────────────────────────────────────
plot(emaFast, "EMA9", color=color.new(color.teal, 0))
plot(emaSlow, "EMA21", color=color.new(color.orange, 0))
plot(vwapVal, "VWAP", color=color.new(color.purple, 30))

// ─── Alerts (configure webhook URL in TradingView alert UI, NOT in script) ───
// Create alert: "Any alert() function call" on SPY chart with this strategy.
alertMsg = '{"ticker":"{{ticker}}","time":"{{timenow}}","price":"{{close}}","interval":"{{interval}}","action":"{{strategy.order.action}}","market_position":"{{strategy.market_position}}","setup":"SPY_0DTE_SCALP","bias":"' + biasStr + '","rsi":"' + str.tostring(rsiVal, "#.##") + '","ema_fast":"' + str.tostring(emaFast, "#.##") + '","ema_slow":"' + str.tostring(emaSlow, "#.##") + '","macd_state":"' + macdStateStr + '","volume_state":"' + volStateStr + '","vwap_state":"' + vwapStateStr + '","atr":"' + str.tostring(atrVal, "#.##") + '","secret":"YOUR_WEBHOOK_SECRET"}'

if canLong
    alert(alertMsg, alert.freq_once_per_bar_close)
if canShort
    alert(alertMsg, alert.freq_once_per_bar_close)
