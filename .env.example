# Application
DEBUG=false
DATABASE_URL=sqlite:///./data/scalper.db

# Webhook security (must match Pine alert "secret" field)
WEBHOOK_SECRET=change-me-in-production

# Feature flags
ENABLE_AI_FILTER=true
ENABLE_NEWS_FILTER=true
ENABLE_BROKER_EXECUTION=false

# Execution — default PAPER only; set LIVE only when ready
EXECUTION_MODE=paper
BROKER_ADAPTER=paper

# AI providers: mock | openai
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# News providers: mock | newsapi
NEWS_PROVIDER=mock
NEWSAPI_KEY=

# Risk preset: conservative | standard | aggressive
RISK_PRESET=standard
MAX_DAILY_LOSS=500
MAX_TRADES_PER_DAY=15
KILL_SWITCH=false

# Options
DEFAULT_DTE=0
DELTA_MIN=0.35
DELTA_MAX=0.55
MAX_SPREAD_PCT=0.15
MAX_HOLD_MINUTES=20
