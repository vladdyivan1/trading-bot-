# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
WEBHOOK_SECRET=optional-tradingview-shared-secret

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/scalper.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/spy_scalper

# Redis (optional — dedup cache)
REDIS_URL=
USE_REDIS=false

# Feature flags
ENABLE_AI_FILTER=true
ENABLE_NEWS_FILTER=true
ENABLE_BROKER_EXECUTION=false
EXECUTION_MODE=paper

# Risk preset: conservative | standard | aggressive
RISK_PRESET=standard
MAX_DAILY_LOSS=500.0
MAX_TRADES_PER_DAY=15
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_STOP_SECONDS=300
DUPLICATE_ALERT_WINDOW_SECONDS=30
STALE_ALERT_SECONDS=60
KILL_SWITCH=false

# Session (ET)
SKIP_FIRST_MINUTES_AFTER_OPEN=5
BLOCK_MAJOR_RELEASES=true

# Options
DEFAULT_DTE=0
FALLBACK_DTE=1
TARGET_DELTA_MIN=0.35
TARGET_DELTA_MAX=0.55
MIN_OPEN_INTEREST=100
MIN_OPTION_VOLUME=50
MAX_SPREAD_PCT=0.15
MAX_HOLD_MINUTES=15
REJECT_LATE_DAY_MINUTES_BEFORE_CLOSE=30

# AI / News
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEWS_PROVIDER=mock
NEWS_API_KEY=
FINNHUB_API_KEY=

# Broker (live — disabled by default)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADIER_ACCESS_TOKEN=
TRADIER_ACCOUNT_ID=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
