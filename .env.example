APP_NAME=ibkr-llm-trading-assistant
ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///ibkr_trading.db

# IBKR (paper trading by default)
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=101
IB_ACCOUNT=

# Safety defaults
PAPER_TRADING_ONLY=true
LIVE_TRADING_ENABLED=false

# LLM provider: openai | anthropic | none
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Risk defaults
MAX_RISK_PER_TRADE_PCT=0.5
MAX_DAILY_LOSS_PCT=2.0
MAX_WEEKLY_LOSS_PCT=5.0
MAX_ACCOUNT_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=10
MAX_CONTRACTS_PER_TRADE=5
MAX_FOREX_LEVERAGE=5.0
MAX_FUTURES_EXPOSURE_PCT=20.0
MAX_OPTIONS_PREMIUM_RISK_PCT=1.0
MIN_REWARD_RISK=1.5
MIN_MODEL_CONFIDENCE=0.65
MIN_BACKTEST_SAMPLE_SIZE=50
MAX_ALLOWED_SPREAD_PCT=0.3
